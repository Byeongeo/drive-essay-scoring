# Gemini
GEMINI_API_KEY=
# 기본값입니다. 필요할 때만 바꿉니다.
GEMINI_MODEL=gemini-3.5-flash

# Google OAuth for Drive connection
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth session protection
# 긴 랜덤 문자열을 넣습니다.
NEXTAUTH_SECRET=
# 로컬 개발: http://localhost:3000
# Vercel 배포 후: https://내프로젝트명.vercel.app
NEXTAUTH_URL=http://localhost:3000
