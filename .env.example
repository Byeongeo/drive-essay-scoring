# Gemini
GEMINI_API_KEY=
# Default model for OCR, rubric extraction, and image-assisted grading.
GEMINI_MODEL=gemini-3.5-flash

# Google OAuth for Drive connection
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth session protection
# Use a long random string.
NEXTAUTH_SECRET=
# Local development: http://localhost:3000
# Vercel deployment: https://your-project-name.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Optional app-wide password gate.
# If set, users must enter this password before using the app or its APIs.
APP_ACCESS_PASSWORD=
